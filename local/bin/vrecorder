#!/bin/sh
# POSIX GPU Screen Recorder.

# Parameters
OUT_DIR="$HOME/Videos/Captures"
DMENU="dmenu -i -p"
FPS="60"
QUALITY="high"
AUDIO="-a default_output|default_input"
TIME="60"

mkdir -p "$OUT_DIR"

# State Resolution (Process ID isolation)
PID=$(pgrep -f "[g]pu-screen-recorder")
IS_REPLAY=$(pgrep -f "[g]pu-screen-recorder.*-r")

notify() {
    command -v notify-send >/dev/null 2>&1 && notify-send -u normal -t 3000 "GSR" "$1"
}

# Execution Subroutines (Mutually Exclusive)
start_replay() {
    [ -n "$PID" ] && exit 1
    notify "Replay Started (${TIME}s)."
    gpu-screen-recorder -w screen -f "$FPS" -q "$QUALITY" $AUDIO -c mkv -r "$TIME" -o "$OUT_DIR" >/tmp/gsr.log 2>&1 &
}

start_record() {
    [ -n "$PID" ] && exit 1
    FILE="$OUT_DIR/Record_$(date +%s).mkv"
    notify "Recording Started."
    gpu-screen-recorder -w screen -f "$FPS" -q "$QUALITY" $AUDIO -c mkv -o "$FILE" >/tmp/gsr.log 2>&1 &
}

stop_process() {
    [ -z "$PID" ] && exit 1
    kill -INT $PID
    notify "Process Terminated."
}

save_clip() {
    [ -n "$IS_REPLAY" ] && kill -USR1 $PID && notify "Clip Saved."
}

# Interface Routing Matrix
menu_ui() {
    if [ -z "$PID" ]; then
        sel=$(printf "Start Replay\nStart Record" | $DMENU "GSR:")
        case "$sel" in
            "Start Replay") start_replay ;;
            "Start Record") start_record ;;
        esac
    elif [ -n "$IS_REPLAY" ]; then
        sel=$(printf "Save Clip\nStop Replay" | $DMENU "GSR [REPLAY]:")
        case "$sel" in
            "Save Clip")   save_clip ;;
            "Stop Replay") stop_process ;;
        esac
    else
        sel=$(printf "Stop Record" | $DMENU "GSR [RECORD]:")
        [ "$sel" = "Stop Record" ] && stop_process
    fi
}

# CLI Dispatcher for Window Manager Binds
case "$1" in
    --replay) start_replay ;;
    --record) if [ -z "$PID" ]; then start_record; else stop_process; fi ;;
    --save)   save_clip ;;
    *)        menu_ui ;;
esac

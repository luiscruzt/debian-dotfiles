#!/usr/bin/env zsh
# smusic: Interactive fuzzy music player and playlist orchestrator.

# --- Documentation ---
if [[ "${1:-}" == "-h" ]] || [[ "${1:-}" == "--help" ]]; then
    cat << 'EOF'
NAME
    smusic - interactive fuzzy music player

SYNOPSIS
    smusic

DESCRIPTION
    smusic provides a TTY-driven interactive interface to search, select, and play 
    audio files. It dynamically enumerates directories and files using fd(1) and 
    filters them via fzf(1). Selected entities are expanded, deduplicated, and 
    serialized into a TOML playlist for playback via cliamp.

ENVIRONMENT
    MUSIC   Base directory for audio files. 
            (Default: /media/luiscruz/Toshiba/Hi-Fi Music)
EOF
    exit 0
fi
# ---------------------

# # TTY Wrapper
# if [[ ! -t 0 ]]; then
#     exec kitty --class smusic_player "$(realpath "$0")" "$@"
# fi

# Dependency Verification
for dep in fzf awk cliamp; do
    if ! command -v "$dep" >/dev/null 2>&1; then
        printf "Error: Mandatory dependency '%s' is not installed.\n" "$dep" >&2
        read -q "?Press any key to exit..." </dev/tty
        exit 1
    fi
done

fd_bin=$(command -v fdfind || command -v fd)
eza_bin=$(command -v eza || command -v exa || command -v ls)

if [[ -z "$fd_bin" ]]; then
    printf "Error: Mandatory dependency 'fd' (or 'fdfind') is not installed.\n" >&2
    exit 1
fi

# Environment Validation
music_dir="${MUSIC:-/media/luiscruz/Toshiba/Hi-Fi Music}"
playlist_dir="$HOME/.config/cliamp/playlists"
toml_file="$playlist_dir/smusic_temp.toml"

if [[ ! -d "$music_dir" ]]; then
    printf "Error: MUSIC directory not found at '%s'\n" "$music_dir" >&2
    exit 1
fi

mkdir -p "$playlist_dir"
cd "$music_dir" || exit 1

# Pipeline
selected=$({
    "$fd_bin" --type directory --color=never .
    "$fd_bin" --type file --color=never \
        -e flac -e mp3 -e m4a -e opus -e ogg -e wav .
} 2>/dev/null | sort | awk -F'/' -v OFS='/' '{
    # Palette Mapping
    c_artist = "\033[35m" # Magenta for Artist/Genre Root
    c_album  = "\033[36m" # Cyan for Album (Direct Parent)
    c_song   = "\033[37m" # White for the File/Song
    c_reset  = "\033[0m"

    # Inject colors dynamically counting backwards from the file
    if (NF >= 3) {
        $NF = c_song $NF c_reset          
        $(NF-1) = c_album $(NF-1) c_reset 
        for (i=1; i<NF-1; i++) {          
            $i = c_artist $i c_reset
        }
    } else if (NF == 2) {
        $1 = c_artist $1 c_reset
        $NF = c_song $NF c_reset
    } else {
        $1 = c_song $1 c_reset
    }
    print $0
}' | fzf --ansi --multi --layout=reverse --scheme=path --tiebreak=length \
    --color="bg+:#24283b,fg+:#c0caf5,hl:#f7768e,hl+:#f7768e,pointer:#7dcfff,prompt:#7aa2f7" \
    --prompt "  Search: " \
    --header "TAB: Select | ENTER: cliamp | C-o: mpv | C-s: splay" \
    --preview "if [ -d {} ]; then $eza_bin -1 --icons --tree --level=1 --color=always {} 2>/dev/null; else $eza_bin -1 --icons --color=always {} 2>/dev/null; fi" \
    --preview-window "right:45%:border-left" \
    --bind "home:first,end:last,ctrl-u:half-page-up,ctrl-d:half-page-down" \
    --bind "shift-up:preview-up,shift-down:preview-down" \
    --bind "ctrl-o:execute-silent(m3u=\"/tmp/sm_mpv_\$\$.m3u\"; awk -v d=\"$PWD\" '{print d\"/\"\$0}' {+f} > \"\$m3u\" && setsid mpv --playlist=\"\$m3u\" >/dev/null 2>&1 &)+deselect-all" \
    --bind "ctrl-s:execute-silent(d=\$(realpath {}); [ -f \"\$d\" ] && d=\$(dirname \"\$d\"); setsid splay \"\$d\" >/dev/null 2>&1 &)+deselect-all")

[[ -z "$selected" ]] && exit 0

# Expansion
local -a audio_files
while IFS= read -r item; do
    if [[ -d "$item" ]]; then
        while IFS= read -r file; do
            audio_files+=("$music_dir/$file")
        done < <("$fd_bin" --type file \
            -e flac -e mp3 -e m4a -e opus -e ogg -e wav \
            . "$item" | sort)
    elif [[ -f "$item" ]]; then
        audio_files+=("$music_dir/$item")
    fi
done <<< "$selected"

# Deduplication
local -a final_files=("${(@u)audio_files}")

if [[ ${#final_files[@]} -eq 0 ]]; then
    exit 0
fi

# Serialization
echo 'name = "smusic_temp"' > "$toml_file"
for file in "${final_files[@]}"; do
    echo '[[track]]' >> "$toml_file"
    
    safe_path="${file//\\/\\\\}"
    safe_path="${safe_path//\"/\\\"}"
    echo "path = \"$safe_path\"" >> "$toml_file"
    
    track_title="${file:t:r}"
    safe_title="${track_title//\\/\\\\}"
    safe_title="${safe_title//\"/\\\"}"
    echo "title = \"$safe_title\"" >> "$toml_file"
done

# Execution Handoff
exec cliamp --playlist "smusic_temp" --auto-play

#!/bin/sh
# NAME
#     vpulse - Volume control via PulseAudio/pactl.
# SYNOPSIS 
#     vpulse <raise|lower|mute|mute-mic>

STEP=5
MAX=100

case "$1" in
    raise)
        VOL=$(pactl get-sink-volume @DEFAULT_SINK@ | awk -F'/' 'NR==1 {gsub(/[^0-9]/,"",$2); print $2}')
        
        if [ "$((VOL + STEP))" -ge "$MAX" ]; then
            pactl set-sink-volume @DEFAULT_SINK@ "${MAX}%"
        else
            pactl set-sink-volume @DEFAULT_SINK@ "+${STEP}%"
        fi
        ;;
    lower)
        pactl set-sink-volume @DEFAULT_SINK@ "-${STEP}%"
        ;;
    mute)
        pactl set-sink-mute @DEFAULT_SINK@ toggle
        ;;
    mute-mic)
        pactl set-source-mute @DEFAULT_SOURCE@ toggle
        ;;
    *)
        printf "Usage: %s <raise|lower|mute|mute-mic>\n" "${0##*/}" >&2
        exit 1
        ;;
esac

pkill -RTMIN+10 i3blocks

#!/bin/sh
# makenote: Fast LaTeX note instantiation for pvault.

PVAULT="$HOME/pvault"
[ ! -d "$PVAULT" ] && mkdir -p "$PVAULT"

# 1. Prompt for subject
SUBJ=$(find "$PVAULT" -mindepth 1 -maxdepth 1 -type d -exec basename {} \; 2>/dev/null | dmenu -i -p "Subject:" < /dev/null)
[ $? -ne 0 ] && exit 1
[ -z "$SUBJ" ] && SUBJ="general"

# 2. Prompt for topic
TOPIC=$(dmenu -p "Topic (Optional):" < /dev/null)
[ $? -ne 0 ] && exit 1

# 3. Format strings and timestamp
TIMESTAMP=$(date +'%Y%m%d_%H%M')

if [ -n "$TOPIC" ]; then
    TOPIC_SANITIZED=$(printf "%s" "$TOPIC" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | tr -s '-' | sed 's/^-//;s/-$//')
    TITLE_CLEAN=$(printf "%s" "$TOPIC" | awk '{for(i=1;i<=NF;i++)sub(/./,toupper(substr($i,1,1)),$i)}1')
    FILENAME="${TIMESTAMP}_${TOPIC_SANITIZED}"
else
    TITLE_CLEAN="Note"
    FILENAME="${TIMESTAMP}"
fi

# 4. Setup directory structure
DIR="$PVAULT/$SUBJ"
mkdir -p "$DIR/figures"

FILEPATH="$DIR/$FILENAME.tex"
[ -f "$FILEPATH" ] && exit 1

# 5. Inject LaTeX template
cat << EOF > "$FILEPATH"
\documentclass[11pt, a4paper]{article}

% Core packages
\usepackage{amsmath, amssymb, amsfonts, amsthm}
\usepackage{graphicx}
\usepackage{hyperref}
\usepackage[margin=1in]{geometry}

% Assets path
\graphicspath{{./figures/}}

\title{$TITLE_CLEAN}
\author{}
\date{\today}

\begin{document}
\maketitle

% Content

\end{document}
EOF

# 6. Compile and open
cd "$DIR" || exit 1

latexmk -pdf -pvc -view=none -interaction=nonstopmode -halt-on-error "$FILENAME.tex" >/dev/null 2>&1 &
COMPILER_PID=$!

# Wait briefly for the first PDF compilation pass before launching sioyek
while [ ! -f "$FILENAME.pdf" ]; do
    sleep 0.1
done

if command -v sioyek >/dev/null 2>&1; then
    sioyek "$FILENAME.pdf" >/dev/null 2>&1 &
fi

# Editor execution block (blocks script until nvim is closed)
if [ -t 0 ]; then
    nvim "$FILENAME.tex"
    exec "${SHELL:-/bin/sh}"
else
    kitty --directory "$DIR" sh -c "nvim $FILENAME.tex"
fi

# 7. Cleanup routine (executes after exiting nvim/kitty)
kill "$COMPILER_PID" >/dev/null 2>&1
rm -f "$DIR"/*.aux "$DIR"/*.log "$DIR"/*.fls "$DIR"/*.fdb_latexmk "$DIR"/*.synctex.gz "$DIR"/*.out

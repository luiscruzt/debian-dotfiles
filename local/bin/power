#!/bin/sh
# power: Power management multiplexer.

ACTIONS="Lock\nLogout\nSuspend\nReboot\nShutdown"

SELECTED=$(printf "$ACTIONS" | dmenu -i -p "System:")
[ -z "$SELECTED" ] && exit 0

CONFIRM=$(printf "No\nYes" | dmenu -i -p "Confirm $SELECTED?")
[ "$CONFIRM" != "Yes" ] && exit 0

case "$SELECTED" in
    Lock)     exec loginctl lock-session ;;
    Logout)   exec i3-msg exit ;;
    Suspend)  exec systemctl suspend ;;
    Reboot)   exec systemctl reboot ;;
    Shutdown) exec systemctl poweroff ;;
    *)        exit 1 ;;
esac

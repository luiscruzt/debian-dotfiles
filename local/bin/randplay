#!/bin/sh
# randplay: random music player for i3wm.

MUSIC_DIR="/media/luiscruz/Toshiba/Hi-Fi Music"
[ ! -d "$MUSIC_DIR" ] && exit 1

ALBUM=$(find "$MUSIC_DIR" -mindepth 2 -maxdepth 2 -type d | shuf -n 1)
[ -z "$ALBUM" ] && exit 0
ALBUM_NAME=$(basename "$ALBUM")

ID=$$
STATUS_CLS="music_status_$ID"
MPV_TTL="music_mpv_gui_$ID"
CAVA_TTL="music_cava_term_$ID"

# spawn primary terminal and mpv instance.
kitty --class="$STATUS_CLS" --title="music_status_term" \
    mpv --force-window=yes --title="$MPV_TTL" "$ALBUM" &
KITTY_PID=$!

# wait for x11 mapping (2.0s timeout).
for i in $(seq 1 20); do
    i3-msg -t get_tree | grep -q "\"name\":\"$MPV_TTL\"" && break
    sleep 0.1
done

# spatial routing via ipc using unique target IDs.
i3-msg "[title=\"$MPV_TTL\"] focus; move right" >/dev/null
i3-msg "[class=\"$STATUS_CLS\"] focus" >/dev/null
i3-msg 'split v' >/dev/null

# spawn spectrum analyzer.
kitty --class="music_cava" --title="$CAVA_TTL" -e cava &
CAVA_PID=$!

# wait for cava mapping.
for i in $(seq 1 20); do
    i3-msg -t get_tree | grep -q "\"name\":\"$CAVA_TTL\"" && break
    sleep 0.1
done

# return input focus to mpv for immediate playback control.
i3-msg "[title=\"$MPV_TTL\"] focus" >/dev/null

# garbage collection.
wait "$KITTY_PID"
kill -TERM "$CAVA_PID" >/dev/null 2>&1

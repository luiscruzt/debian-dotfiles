#!/usr/bin/env sh
# makenote: LaTeX and Typst note initialization script.

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
    cat << 'EOF'
NAME
    makenote - LaTeX and Typst note initialization script

SYNOPSIS
    makenote

DESCRIPTION
    An interactive tool to scaffold notes. It infers the filetype 
    from the input (e.g., 'calculus.tex' or 'forces.typ'), sets up 
    the directory structure, generates templates, and runs the 
    background compilers and PDF viewers.

ENVIRONMENT
    MAKENOTE_VAULT    Root directory (Default: ~/my-notes)
    EDITOR            Text editor (Default: nvim)
EOF
    exit 0
fi

# Setup base directory and taxonomy
VAULT="${MAKENOTE_VAULT:-$HOME/my-notes}"
TAXONOMY="general mathematics physics engineering computer-science philosophy"

for subj in $TAXONOMY; do
    mkdir -p "$VAULT/$subj/figures"
done

# Subject selection with robust eza preview
SUBJ=$(find "$VAULT" -mindepth 1 -maxdepth 1 -type d | sed "s|^$VAULT/||" | sort | \
    fzf --prompt="Subject > " \
        --preview "DIR='$VAULT/{}'; if [ -z \"\$(ls -A \"\$DIR\" 2>/dev/null)\" ]; then echo 'Empty Directory'; elif command -v eza >/dev/null 2>&1; then eza -1 --color=always --icons \"\$DIR\"; else ls -1 \"\$DIR\"; fi" \
        --preview-window "right:45%:border-left" \
        --print-query | tail -n 1)
[ -z "$SUBJ" ] && exit 0

DIR="$VAULT/$SUBJ"
mkdir -p "$DIR/figures"

# Pure minimalist prompt
printf "> "
read -r INPUT
[ -z "$INPUT" ] && exit 0

# Parse extension and exact base name
case "$INPUT" in
    *.*) EXT="${INPUT##*.}" ; RAW_TITLE="${INPUT%.*}" ;;
    *)   EXT="tex" ; RAW_TITLE="$INPUT" ;;
esac

if [ "$EXT" != "tex" ] && [ "$EXT" != "typ" ]; then
    printf "Error: Only .tex and .typ are supported.\n" >&2
    exit 1
fi

# Exact preservation for the document header
TITLE="$RAW_TITLE"

# Format strictly for the UNIX filename
TIMESTAMP=$(date +'%Y%m%d_%H%M')
CLEAN_NAME=$(printf "%s" "$RAW_TITLE" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | tr -s '-' | sed 's/^-//;s/-$//')
FILENAME="${TIMESTAMP}_${CLEAN_NAME}"

# Generate template
if [ "$EXT" = "tex" ]; then
    cat << EOF > "$DIR/$FILENAME.tex"
\documentclass[11pt, a4paper]{article}
\usepackage{amsmath, amssymb, amsfonts, amsthm}
\usepackage{graphicx}
\usepackage{hyperref}
\usepackage[margin=1in]{geometry}
\graphicspath{{./figures/}}

\title{$TITLE}
\author{}
\date{\today}

\begin{document}
\maketitle

\end{document}
EOF
else
    cat << EOF > "$DIR/$FILENAME.typ"
#set document(title: "$TITLE")
#set page(paper: "a4", margin: 1in)
#set text(font: "Linux Libertine", size: 11pt)

= $TITLE

EOF
fi

cd "$DIR" || exit 1

COMPILER_PID=""
VIEWER_PID=""

# Clean up specific background PIDs and exact build files on exit
cleanup() {
    [ -n "$COMPILER_PID" ] && kill "$COMPILER_PID" >/dev/null 2>&1 || true
    [ -n "$VIEWER_PID" ] && kill "$VIEWER_PID" >/dev/null 2>&1 || true
    
    rm -f "$FILENAME".aux "$FILENAME".log "$FILENAME".fls "$FILENAME".fdb_latexmk \
          "$FILENAME".synctex.gz "$FILENAME".out "$FILENAME".bbl "$FILENAME".bcf \
          "$FILENAME".run.xml "$FILENAME".blg >/dev/null 2>&1 || true
}
trap cleanup EXIT

# Start compiler and explicit PID capture
if [ "$EXT" = "tex" ]; then
    latexmk -pdf -synctex=1 -pvc -view=none -interaction=nonstopmode -halt-on-error "$FILENAME.tex" >/dev/null 2>&1 &
    COMPILER_PID=$!
else
    typst watch "$FILENAME.typ" "$FILENAME.pdf" >/dev/null 2>&1 &
    COMPILER_PID=$!
fi

# Start viewer subshell and explicit PID capture
(
    while [ ! -f "$FILENAME.pdf" ]; do sleep 0.2; done
    sioyek "$FILENAME.pdf" >/dev/null 2>&1
) &
VIEWER_PID=$!

# Launch editor
${EDITOR:-nvim} "$FILENAME.$EXT"

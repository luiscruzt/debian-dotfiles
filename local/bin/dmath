#!/bin/sh
# dm-math: minimalist scientific calculator via bc

SCALE=4
DMENU_P="dmenu -p"

EXPR=$(: | $DMENU_P "Math:")
[ -z "$EXPR" ] && exit 0

RES=$(echo "scale=$SCALE; $EXPR" | bc -l | sed 's/^\./0./')

if [ -n "$RES" ]; then
    echo "$RES" | xclip -selection clipboard
    notify-send "Math Result" "$EXPR = $RES"
fi

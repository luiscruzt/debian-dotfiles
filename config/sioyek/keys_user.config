
# ---------------------------------------------------------
# MOVEMENT (Vim Standard)
# ---------------------------------------------------------

move_down           j
move_up             k
move_left           h
move_right          l

# Half-page scrolling
screen_down         <d>
screen_up           <u>

# Full page sequential
next_page           J
previous_page       K

# Document extremes
goto_beginning      gg
goto_end            G

# ---------------------------------------------------------
# JUMPS (State Tracking)
# ---------------------------------------------------------

# Return to previous spatial location
prev_state          <C-o>
# Move forward in spatial history
next_state          <C-i>

# ---------------------------------------------------------
# INTERFACE & UI MANIPULATION
# ---------------------------------------------------------

toggle_custom_color i
toggle_statusbar    <C-b>
toggle_visual_mark  v

# Zoom mechanics
zoom_in             =
zoom_out            -
fit_to_page_width   w

# ---------------------------------------------------------
# 4. YANK & SEARCH
# ---------------------------------------------------------

copy                y
copy                <C-c>

search              /
next_item           n
previous_item       N
